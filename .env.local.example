# Copy to .env.local (gitignored). Each project that has a live backend gets its
# own NEXT_PUBLIC_*_API_BASE. The browser calls these directly, so they must be
# the PUBLIC https URL, and the frontend's origin must be in that backend's
# ALLOWED_ORIGINS (CORS) or the browser blocks the request.

# RetrofitGPT backend (VPS, behind Caddy TLS):
NEXT_PUBLIC_API_BASE=https://204-168-226-100.sslip.io
